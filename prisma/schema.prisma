generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model categorias {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre      String    @unique @db.VarChar(100)
  descripcion String?
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
}

model proveedores {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre           String             @db.VarChar(100)
  tipo             String             @db.VarChar(20)
  url_api_base     String
  activo           Boolean?           @default(true)
  created_at       DateTime?          @default(now()) @db.Timestamptz(6)
  detalles_reserva detalles_reserva[]
  items_carrito    items_carrito[]
}

model carritos {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  id_cliente    String?         @db.Uuid
  estado        String?         @default("ACTIVO") @db.VarChar(20)
  total         Decimal?        @default(0) @db.Decimal(10, 2)
  created_at    DateTime?       @default(now()) @db.Timestamptz(6)
  items_carrito items_carrito[]
}

model items_carrito {
  id                  String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  id_carrito          String?      @db.Uuid
  id_proveedor        String?      @db.Uuid
  id_producto_externo String?
  nombre_producto     String?
  cantidad            Int?         @default(1)
  precio_unitario     Decimal      @db.Decimal(10, 2)
  metadata            Json?
  created_at          DateTime?    @default(now()) @db.Timestamptz(6)
  carritos            carritos?    @relation(fields: [id_carrito], references: [id], onDelete: Cascade, onUpdate: NoAction)
  proveedores         proveedores? @relation(fields: [id_proveedor], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([id_proveedor])
}

model reservas {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  id_cliente       String?            @db.Uuid
  total            Decimal            @db.Decimal(10, 2)
  status           String?            @default("PAGADA") @db.VarChar(50)
  fecha_reserva    DateTime?          @default(now()) @db.Timestamptz(6)
  created_at       DateTime?          @default(now()) @db.Timestamptz(6)
  detalles_reserva detalles_reserva[]
}

model detalles_reserva {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  id_reserva      String?      @db.Uuid
  id_proveedor    String?      @db.Uuid
  id_externo      String?      @db.VarChar(255)
  id_externo_codigo String?    @db.VarChar(255)
  cantidad        Int
  precio_unitario Decimal      @db.Decimal(10, 2)
  status          String       @default("CONFIRMADA") @db.VarChar(50)
  created_at      DateTime?    @default(now()) @db.Timestamptz(6)
  proveedores     proveedores? @relation(fields: [id_proveedor], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reservas        reservas?    @relation(fields: [id_reserva], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model auditoria {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  id_usuario String?  @db.Uuid
  accion     String   @db.VarChar(100)
  tabla      String   @db.VarChar(100)
  detalles   String?
  ip         String?  @db.VarChar(50)
  fecha      DateTime @default(now()) @db.Timestamptz(6)
}

// ── V2 EventBus ─────────────────────────────────────────────────────────────
// Tablas nuevas para el orquestador V2 (saga choreography por RabbitMQ).
// Conviven con la BD de Supabase existente — atomicidad outbox+negocio en
// la misma transacción.

model event_outbox {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_id       String    @unique @db.Uuid
  event_type     String    @db.VarChar(100)
  exchange       String    @db.VarChar(100)
  routing_key    String    @db.VarChar(100)
  payload        Json
  correlation_id String?   @db.Uuid
  aggregate_id   String?   @db.VarChar(100)
  created_at     DateTime  @default(now()) @db.Timestamptz(6)
  published_at   DateTime? @db.Timestamptz(6)
  attempts       Int       @default(0)
  last_error     String?

  @@index([created_at], map: "idx_event_outbox_unpublished")
  @@index([correlation_id], map: "idx_event_outbox_correlation")
  @@index([aggregate_id], map: "idx_event_outbox_aggregate")
}

model processed_messages {
  event_id     String   @id @db.Uuid
  event_type   String   @db.VarChar(100)
  processed_at DateTime @default(now()) @db.Timestamptz(6)
}

// Saga state machine — único de este repo.
// Una row por checkout/cancelación. `current_step` avanza linealmente.
// El consumer actualiza con `update WHERE current_step = expected_from` para
// evitar races. `pending_command_id` se setea al publicar un comando y se
// matchea al recibir el evento de respuesta via causationId.
model saga_state {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reserva_id             String    @unique @db.Uuid
  saga_type              String    @db.VarChar(30) // CHECKOUT | CANCELLATION
  current_step           String    @db.VarChar(50)
  total_items            Int       @default(0)
  items_created          Int       @default(0)
  items_confirmed        Int       @default(0)
  items_cancelled        Int       @default(0)
  pending_command_id     String?   @db.Uuid
  payment_id             String?   @db.Uuid
  invoice_id             String?   @db.Uuid
  last_error             String?
  context                Json?     // payload extra (metodoPagoId, currency, etc)
  correlation_id         String    @db.Uuid
  created_at             DateTime  @default(now()) @db.Timestamptz(6)
  updated_at             DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  completed_at           DateTime? @db.Timestamptz(6)

  @@index([current_step], map: "idx_saga_state_step")
  @@index([updated_at], map: "idx_saga_state_updated")
  @@index([pending_command_id], map: "idx_saga_state_pending_cmd")
}

// Idempotencia HTTP capa 1 — único de este repo.
// El cliente puede mandar `Idempotency-Key` header. Si el mismo header llega 2
// veces, la 2ª devuelve la respuesta cacheada de la 1ª (no re-procesa).
model idempotency_keys {
  key          String   @id @db.VarChar(255)
  endpoint     String   @db.VarChar(100)
  response     Json
  status_code  Int
  created_at   DateTime @default(now()) @db.Timestamptz(6)

  @@index([created_at], map: "idx_idempotency_keys_created")
}
